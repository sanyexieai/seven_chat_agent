# 本地 Docker 开发（复制为 deploy/.env.local）
#   cp deploy/.env.local.example deploy/.env.local

# 宿主机端口映射：HOST_BIND=0.0.0.0 对局域网开放；仅本机用 127.0.0.1
HOST_BIND=0.0.0.0
SERVER_PORT=18737
SERVER_HTTPS_PORT=18743

HONEYCOMB_BIND=0.0.0.0:18737
HONEYCOMB_DATA=/app/data
HONEYCOMB_DB=sqlite:///app/data/seven_chat_agent.db

# 本地调试建议关闭强制登录
SEVEN_CHAT_AGENT_AUTH_REQUIRED=0

# 容器内访问宿主机 Ollama（Linux 可用 host-gateway；Docker Desktop 亦支持）
# OLLAMA_HOST=http://host.docker.internal:11434

# CLI 配对 / 外网访问（把 HOST 换成机器局域网 IP 或域名）
# SEVEN_CHAT_AGENT_PUBLIC_HOST=192.168.1.100
# SEVEN_CHAT_AGENT_RELAY_WS_URL=ws://192.168.1.100:18737/cli-relay

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
