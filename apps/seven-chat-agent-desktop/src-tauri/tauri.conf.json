{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Seven Chat Agent",
  "version": "0.1.0",
  "identifier": "com.sanyexieai.seven-chat-agent",
  "build": {
    "beforeDevCommand": "npm --prefix ../../web run dev",
    "devUrl": "http://127.0.0.1:18738",
    "beforeBuildCommand": "npm --prefix ../../web run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Seven Chat Agent",
        "label": "main",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:18739/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "类微信多 Agent 聊天室",
    "longDescription": "把 CLI AI、API 模型、自主进化助理与真人好友放进一个聊天界面。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "targets": ["msi", "dmg", "appimage", "deb", "nsis"],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
