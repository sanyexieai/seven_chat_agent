# 复制为 deploy/.env（勿提交密钥）
#   cp deploy/.env.example deploy/.env
#
# docker compose 会加载本文件（env_file），并叠加 docker-compose.yml 中的默认值。

# ══════════════════════════════════════════════════════
# 部署 / 镜像
# ══════════════════════════════════════════════════════
REGISTRY=3ye.co:9443
IMAGE_TAG=latest
SERVER_IMAGE=3ye.co:9443/seven-chat-agent/server:latest
SERVER_PORT=18737
SERVER_HTTPS_PORT=18743

# ══════════════════════════════════════════════════════
# 服务（容器内路径，与 compose 默认一致，一般不用改）
# ══════════════════════════════════════════════════════
HONEYCOMB_BIND=0.0.0.0:18737
HONEYCOMB_DATA=/app/data
HONEYCOMB_DB=sqlite:///app/data/seven_chat_agent.db
SEVEN_CHAT_AGENT_STATIC_DIR=/app/web/dist
SEVEN_CHAT_AGENT_VAULT=/app/data/vault.json
SEVEN_CHAT_AGENT_SKILLS_DIR=/app/data/skills
SEVEN_CHAT_AGENT_CLI_WORKSPACE_ROOT=/app/data/cli-workspaces
SEVEN_CHAT_AGENT_CLI_AUTO_GIT=1

# 多租户 / 登录（release 镜像默认要求登录；调试可设 0）
# SEVEN_CHAT_AGENT_AUTH_REQUIRED=0
# SEVEN_CHAT_AGENT_TENANT_ID=default
# SEVEN_CHAT_AGENT_SESSION_TTL_DAYS=30
# SEVEN_CHAT_AGENT_UPLOAD_MAX_BYTES=10485760

# ══════════════════════════════════════════════════════
# 助理默认模型
# ══════════════════════════════════════════════════════
SEVEN_CHAT_AGENT_ASSISTANT_PROVIDER=deepseek
SEVEN_CHAT_AGENT_ASSISTANT_MODEL=deepseek-v4-flash
# SEVEN_CHAT_AGENT_JUDGE_PROVIDER=
# SEVEN_CHAT_AGENT_JUDGE_MODEL=

# ══════════════════════════════════════════════════════
# HTTPS（可选；不填则仅 HTTP 18737）
# 启用时：取消 docker-compose.yml 中证书 volume 注释，并填写下面几项
# ══════════════════════════════════════════════════════
# TLS_CERTS_DIR=/etc/letsencrypt
# TLS_CERT_DOMAIN=3ye.co
# HONEYCOMB_HTTPS_BIND=0.0.0.0:18743
# HONEYCOMB_TLS_CERT=/app/certs/live/3ye.co/fullchain.crt
# HONEYCOMB_TLS_KEY=/app/certs/live/3ye.co/3ye.co.key
# 前面有 Nginx 443 终结 TLS 时：
# HONEYCOMB_PUBLIC_HTTPS_PORT=443

# ══════════════════════════════════════════════════════
# API Key（按需填写；也可在 Web「设置」里配置）
# ══════════════════════════════════════════════════════
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
MOONSHOT_API_KEY=
OPENROUTER_API_KEY=

# 本地 Ollama（容器访问宿主机示例；按实际改 host）
# OLLAMA_HOST=http://host.docker.internal:11434

# ══════════════════════════════════════════════════════
# CLI relay（可选 profile relay）
# ══════════════════════════════════════════════════════
RELAY_PAIRING_TOKEN=pair_xxxxxxxx
RELAY_URL=ws://server:18737/cli-relay
RELAY_NAME=prod-relay
