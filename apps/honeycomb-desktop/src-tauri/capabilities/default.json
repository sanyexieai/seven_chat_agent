{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-set-title",
    "core:webview:allow-set-webview-zoom"
  ]
}
