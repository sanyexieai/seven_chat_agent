# Seven Chat Agent（seven_chat_agent v2）环境变量示例
# 用法：cp .env.example .env ，填入密钥后启动服务（server 会自动加载项目根目录 .env）
#
# API Key 用于配置「工蜂 CLI 实例」所绑定的平台（非与 CLI 平级的独立 API 好友）
# 优先级：Web「设置」里配置的 Key > 本文件环境变量
# 命名：<PROVIDER_ID>_API_KEY（ID 大写，横线改下划线）

# ── 服务 ──────────────────────────────────────────────
HONEYCOMB_BIND=127.0.0.1:18737
HONEYCOMB_DB=sqlite://data/honeycomb.db
HONEYCOMB_DATA=data
HONEYCOMB_VAULT=data/vault.json
# HONEYCOMB_STATIC_DIR=web/dist
# HONEYCOMB_SERVER=http://127.0.0.1:18737

# ── 助理默认模型（backend_config 未指定时）────────────
HONEYCOMB_ASSISTANT_PROVIDER=deepseek
HONEYCOMB_ASSISTANT_MODEL=deepseek-v4-flash

# ── 群聊裁判（可选）──────────────────────────────────
# HONEYCOMB_JUDGE_MODEL=gpt-4o-mini

# ── CLI 工作区 ────────────────────────────────────────
# HONEYCOMB_CLI_CWD=
# HONEYCOMB_CLI_WORKSPACE_ROOT=data/cli-workspaces
# HONEYCOMB_CLI_AUTO_GIT=1
HONEYCOMB_SKILLS_DIR=data/skills

# ── Worker Bee CLI（工蜂，独立 crate worker-bee-cli）──
# 好友 backend_config 未填 provider/model 时，工蜂实例会按下列顺序加载（后者覆盖前者）：
#   WORKER_BEE_* → HONEYCOMB_ASSISTANT_* → 扫描下方 * _API_KEY → 内置默认
# 未安装到 PATH 时，先 cargo build -p worker-bee-cli --bin worker-bee
# 再设绝对路径（与 honeycomb-server 同在 target/debug/ 下）：
# HONEYCOMB_WORKER_BEE_BIN=/你的仓库路径/target/debug/worker-bee
# WORKER_BEE_PROVIDER_ID=deepseek
# WORKER_BEE_MODEL=deepseek-v4-flash
# WORKER_BEE_WORKSPACE=
# WORKER_BEE_DATA=
# WORKER_BEE_SKILLS_DIR=data/skills

# ══════════════════════════════════════════════════════
# 云端 API Key（按需填写，名称与内置 Provider id 对应）
# ══════════════════════════════════════════════════════

# OpenAI — provider_id: openai
OPENAI_API_KEY=

# Anthropic — provider_id: anthropic
ANTHROPIC_API_KEY=

# Google Gemini — provider_id: gemini
GEMINI_API_KEY=

# DeepSeek — provider_id: deepseek
DEEPSEEK_API_KEY=

# 通义千问 DashScope 兼容模式 — provider_id: qwen
QWEN_API_KEY=

# Moonshot Kimi — provider_id: moonshot
MOONSHOT_API_KEY=

# OpenRouter — provider_id: openrouter
OPENROUTER_API_KEY=

# ══════════════════════════════════════════════════════
# 本地 / 自建（通常不需要 Key；若网关要求鉴权可填）
# ══════════════════════════════════════════════════════

# Ollama — provider_id: ollama，默认 http://localhost:11434
# OLLAMA_API_KEY=

# LM Studio — provider_id: lmstudio，默认 http://localhost:1234/v1
# LMSTUDIO_API_KEY=

# vLLM — provider_id: vllm，默认 http://localhost:8000/v1
# VLLM_API_KEY=

# ── 自定义 Provider ───────────────────────────────────
# 在 Web「设置」里新增的 Provider，环境变量名为 <你的provider_id>_API_KEY
# 例如新增 id=my-gpt 则使用：
# MY_GPT_API_KEY=
